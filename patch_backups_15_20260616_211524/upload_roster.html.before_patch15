<!DOCTYPE html>
<html>
<head>
    <title>Upload Roster</title>
</head>
<body>

<h1>Upload Weekly Roster</h1>

<form method="post" enctype="multipart/form-data">
    {% csrf_token %}

    <p>
        Select roster CSV:<br>
        <input type="file" name="roster_file" accept=".csv">
    </p>

    <button type="submit">Upload Roster</button>
</form>

<h3>{{ message }}</h3>

<p><a href="/admin/">Back to Admin</a></p>

</body>
</html>
