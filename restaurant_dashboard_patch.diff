+def calculate_day_metrics(employee, selected_date):
+    """
+    Calculates daily attendance, break and compliance information for one employee.
+    This is deliberately plain and readable for PoC development.
+    """
+    events = ClockEvent.objects.filter(
+        employee=employee,
+        timestamp__date=selected_date
+    ).order_by("timestamp")
+
+    shifts = RosterShift.objects.filter(
+        employee=employee,
+        shift_date=selected_date
+    ).order_by("start_time")
+
+    roster_text = "Not rostered"
+    roster_minutes = 0
+
+    if shifts.exists():
+        parts = []
+        for shift in shifts:
+            parts.append(
+                f"{shift.start_time.strftime('%H:%M')} - {shift.end_time.strftime('%H:%M')}"
+            )
+            start_dt = datetime.combine(shift.shift_date, shift.start_time)
+            end_dt = datetime.combine(shift.shift_date, shift.end_time)
+            if end_dt <= start_dt:
+                end_dt += timedelta(days=1)
+            roster_minutes += int((end_dt - start_dt).total_seconds() / 60)
+        roster_text = ", ".join(parts)
+
+    first_in = None
+    last_out = None
+    latest_event = events.last()
+
+    gross_worked_minutes = 0
+    break_minutes = 0
+
+    active_work_start = None
+    active_break_start = None
+    has_invalid_sequence = False
+
+    for event in events:
+        if event.clock_type == "IN":
+            if first_in is None:
+                first_in = event.timestamp
+            if active_work_start is not None:
+                has_invalid_sequence = True
+            active_work_start = event.timestamp
+
+        elif event.clock_type == "BREAK_START":
+            if active_work_start is None:
+                has_invalid_sequence = True
+            else:
+                gross_worked_minutes += int((event.timestamp - active_work_start).total_seconds() / 60)
+                active_work_start = None
+            active_break_start = event.timestamp
+
+        elif event.clock_type == "BREAK_END":
+            if active_break_start is None:
+                has_invalid_sequence = True
+            else:
+                break_minutes += int((event.timestamp - active_break_start).total_seconds() / 60)
+                active_break_start = None
+            active_work_start = event.timestamp
+
+        elif event.clock_type == "OUT":
+            last_out = event.timestamp
+            if active_break_start is not None:
+                break_minutes += int((event.timestamp - active_break_start).total_seconds() / 60)
+                active_break_start = None
+            elif active_work_start is not None:
+                gross_worked_minutes += int((event.timestamp - active_work_start).total_seconds() / 60)
+                active_work_start = None
+            else:
+                has_invalid_sequence = True
+
+    current_status = "No activity"
+    if latest_event:
+        if latest_event.clock_type == "IN":
+            current_status = "Currently working"
+        elif latest_event.clock_type == "BREAK_START":
+            current_status = "On break"
+        elif latest_event.clock_type == "BREAK_END":
+            current_status = "Back from break"
+        elif latest_event.clock_type == "OUT":
+            current_status = "Clocked out"
+
+    now = timezone.now()
+    live_minutes = 0
+    if selected_date == timezone.localdate():
+        if active_work_start is not None:
+            live_minutes = int((now - active_work_start).total_seconds() / 60)
+        elif active_break_start is not None:
+            live_minutes = int((now - active_break_start).total_seconds() / 60)
+
+    display_worked_minutes = gross_worked_minutes
+    if selected_date == timezone.localdate() and active_work_start is not None:
+        display_worked_minutes += live_minutes
+
+    paid_minutes = max(gross_worked_minutes, 0)
+
+    required_break_minutes = 0
+    if display_worked_minutes > 360:
+        required_break_minutes = 30
+    elif display_worked_minutes > 270:
+        required_break_minutes = 15
+
+    compliance = "OK"
+    attention = False
+
+    if has_invalid_sequence:
+        compliance = "Check clock sequence"
+        attention = True
+    elif latest_event and not shifts.exists():
+        compliance = "Worked but not rostered"
+        attention = True
+    elif shifts.exists() and not latest_event:
+        compliance = "Rostered but no clock-in"
+        attention = True
+    elif latest_event and latest_event.clock_type == "IN" and required_break_minutes > 0 and break_minutes == 0:
+        compliance = "Break due / overdue"
+        attention = True
+    elif required_break_minutes > 0 and break_minutes < required_break_minutes and latest_event and latest_event.clock_type == "OUT":
+        compliance = "Break missing or too short"
+        attention = True
+
+    return {
+        "employee_number": employee.employee_number,
+        "employee": employee.name,
+        "roster": roster_text,
+        "first_in": first_in.strftime("%H:%M") if first_in else "-",
+        "last_out": last_out.strftime("%H:%M") if last_out else "-",
+        "latest_event": latest_event.clock_type if latest_event else "-",
+        "status": current_status,
+        "worked_hours": round(display_worked_minutes / 60, 2),
+        "break_minutes": break_minutes,
+        "paid_hours": round(paid_minutes / 60, 2),
+        "required_break_minutes": required_break_minutes,
+        "compliance": compliance,
+        "attention": attention,
+        "event_count": events.count(),
+    }
+
+
+def compliance_dashboard(request):
+    selected_date_str = request.GET.get(
+        "date",
+        timezone.localdate().strftime("%Y-%m-%d")
+    )
+    selected_date = datetime.strptime(selected_date_str, "%Y-%m-%d").date()
+
+    employees = Employee.objects.filter(active=True).order_by("name")
+    rows = [calculate_day_metrics(employee, selected_date) for employee in employees]
+
+    currently_working = sum(1 for row in rows if row["status"] in ["Currently working", "Back from break"])
+    on_break = sum(1 for row in rows if row["status"] == "On break")
+    requiring_attention = sum(1 for row in rows if row["attention"])
+    break_issues = sum(1 for row in rows if "Break" in row["compliance"] or "break" in row["compliance"])
+
+    attention_rows = [row for row in rows if row["attention"]]
+
+    return render(request, "compliance_dashboard.html", {
+        "selected_date": selected_date,
+        "rows": rows,
+        "attention_rows": attention_rows,
+        "currently_working": currently_working,
+        "on_break": on_break,
+        "requiring_attention": requiring_attention,
+        "break_issues": break_issues,
+    })
