+<!DOCTYPE html>
+<html>
+<head>
+    <title>Compliance Dashboard</title>
+    <style>
+        body {
+            font-family: Arial, sans-serif;
+            margin: 30px;
+            background: #f7f7f7;
+        }
+        .container {
+            max-width: 1200px;
+            background: white;
+            padding: 25px;
+            border-radius: 10px;
+        }
+        .cards {
+            display: flex;
+            gap: 15px;
+            flex-wrap: wrap;
+            margin: 20px 0;
+        }
+        .card {
+            flex: 1;
+            min-width: 180px;
+            padding: 18px;
+            border-radius: 8px;
+            background: #f1f4f8;
+            border: 1px solid #ddd;
+        }
+        .number {
+            font-size: 34px;
+            font-weight: bold;
+        }
+        table {
+            width: 100%;
+            border-collapse: collapse;
+            margin-top: 15px;
+        }
+        th, td {
+            border: 1px solid #ddd;
+            padding: 10px;
+            text-align: left;
+        }
+        th {
+            background: #eef2f7;
+        }
+        .ok {
+            color: #1a7f37;
+            font-weight: bold;
+        }
+        .warn {
+            color: #b42318;
+            font-weight: bold;
+        }
+        .toolbar {
+            margin: 15px 0;
+        }
+        a.button {
+            display: inline-block;
+            padding: 8px 12px;
+            background: #2f6fed;
+            color: white;
+            text-decoration: none;
+            border-radius: 5px;
+            margin-right: 6px;
+        }
+        .plain {
+            background: #555 !important;
+        }
+    </style>
+</head>
+<body>
+
+<div class="container">
+
+<h1>Manager Compliance Dashboard</h1>
+
+<p>
+This is the main manager view. It shows who is currently working, who is on break,
+who needs attention and whether unpaid break rules appear to be satisfied.
+</p>
+
+<form method="get">
+    Date:
+    <input type="date" name="date" value="{{ selected_date|date:'Y-m-d' }}">
+    <button type="submit">View Date</button>
+</form>
+
+<h2>{{ selected_date }}</h2>
+
+<div class="cards">
+    <div class="card">
+        <div>Currently Working</div>
+        <div class="number">{{ currently_working }}</div>
+    </div>
+    <div class="card">
+        <div>On Break</div>
+        <div class="number">{{ on_break }}</div>
+    </div>
+    <div class="card">
+        <div>Need Attention</div>
+        <div class="number">{{ requiring_attention }}</div>
+    </div>
+    <div class="card">
+        <div>Break Issues</div>
+        <div class="number">{{ break_issues }}</div>
+    </div>
+</div>
+
+<h2>Needs Attention</h2>
+
+<table>
+    <tr>
+        <th>Employee</th>
+        <th>Status</th>
+        <th>Issue</th>
+        <th>Worked</th>
+        <th>Break</th>
+        <th>Paid</th>
+    </tr>
+    {% for row in attention_rows %}
+    <tr>
+        <td>{{ row.employee }}</td>
+        <td>{{ row.status }}</td>
+        <td class="warn">{{ row.compliance }}</td>
+        <td>{{ row.worked_hours }}</td>
+        <td>{{ row.break_minutes }} mins</td>
+        <td>{{ row.paid_hours }}</td>
+    </tr>
+    {% empty %}
+    <tr>
+        <td colspan="6" class="ok">No issues requiring attention.</td>
+    </tr>
+    {% endfor %}
+</table>
+
+<h2>All Staff</h2>
+
+<table>
+    <tr>
+        <th>Employee No</th>
+        <th>Employee</th>
+        <th>Roster</th>
+        <th>First In</th>
+        <th>Last Out</th>
+        <th>Status</th>
+        <th>Worked</th>
+        <th>Break</th>
+        <th>Paid</th>
+        <th>Compliance</th>
+    </tr>
+    {% for row in rows %}
+    <tr>
+        <td>{{ row.employee_number }}</td>
+        <td>{{ row.employee }}</td>
+        <td>{{ row.roster }}</td>
+        <td>{{ row.first_in }}</td>
+        <td>{{ row.last_out }}</td>
+        <td>{{ row.status }}</td>
+        <td>{{ row.worked_hours }}</td>
+        <td>{{ row.break_minutes }} mins</td>
+        <td>{{ row.paid_hours }}</td>
+        <td class="{% if row.attention %}warn{% else %}ok{% endif %}">
+            {{ row.compliance }}
+        </td>
+    </tr>
+    {% endfor %}
+</table>
+
+<div class="toolbar">
+    <a class="button" href="/clock/">Staff Clocking</a>
+    <a class="button" href="/manager/upload-roster/">Upload Roster</a>
+    <a class="button" href="/manager/weekly-summary/?week_start=2026-06-15">Weekly Summary</a>
+    <a class="button plain" href="/">Home</a>
+</div>
+
+</div>
+
+</body>
+</html>
